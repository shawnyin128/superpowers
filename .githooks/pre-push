#!/usr/bin/env bash
#
# Pre-push hook: detect change type, suggest version bump.
# Non-blocking — prints recommendation for agent to execute.
#
# Install: git config core.hooksPath .githooks
#

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# Get current version
current_version=$(jq -r '.version' "$REPO_ROOT/package.json")
IFS='.' read -r major minor patch <<< "$current_version"

# Determine remote ref to compare against
remote_ref=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo "")
if [ -z "$remote_ref" ]; then
  exit 0
fi
remote_sha=$(git rev-parse "$remote_ref" 2>/dev/null || echo "")
if [ -z "$remote_sha" ]; then
  exit 0
fi

# Check if version already bumped
version_changed=$(git diff "$remote_sha" HEAD -- package.json | grep '"version"' || true)
if [ -n "$version_changed" ]; then
  exit 0
fi

# Detect change types
changed_files=$(git diff --name-only "$remote_sha" HEAD 2>/dev/null || echo "")
if [ -z "$changed_files" ]; then
  exit 0
fi

# Classify changes
has_major=false
has_minor=false
has_patch=false

# MAJOR: plugin metadata changes, skill directory renames/deletes
if echo "$changed_files" | grep -q '\.claude-plugin/\|\.cursor-plugin/'; then
  # Check if name field changed (not just version)
  name_changed=$(git diff "$remote_sha" HEAD -- .claude-plugin/plugin.json | grep '"name"' || true)
  if [ -n "$name_changed" ]; then
    has_major=true
  fi
fi
# Check for deleted skill directories
deleted_skills=$(git diff --diff-filter=D --name-only "$remote_sha" HEAD -- skills/ | grep 'SKILL.md' || true)
if [ -n "$deleted_skills" ]; then
  has_major=true
fi

# MINOR: new skill directories
new_skills=$(git diff --diff-filter=A --name-only "$remote_sha" HEAD -- skills/ | grep 'SKILL.md' || true)
if [ -n "$new_skills" ]; then
  has_minor=true
fi

# PATCH: skill content modifications
modified_skills=$(git diff --diff-filter=M --name-only "$remote_sha" HEAD -- skills/ || true)
if [ -n "$modified_skills" ]; then
  has_patch=true
fi

# No skill-related changes
if ! $has_major && ! $has_minor && ! $has_patch; then
  exit 0
fi

# Compute suggested version
if $has_major; then
  suggested="$((major + 1)).0.0"
  bump_type="MAJOR (breaking: plugin rename or skill deleted)"
elif $has_minor; then
  suggested="${major}.$((minor + 1)).0"
  bump_type="MINOR (new skill added)"
else
  suggested="${major}.${minor}.$((patch + 1))"
  bump_type="PATCH (skill content modified)"
fi

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "⚠️  VERSION BUMP NEEDED"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
echo "Current: $current_version"
echo "Suggested: $suggested ($bump_type)"
echo ""
if [ -n "$new_skills" ]; then
  echo "New skills:"
  echo "$new_skills" | sed 's|skills/||;s|/SKILL.md||' | sed 's/^/  + /'
fi
if [ -n "$modified_skills" ]; then
  echo "Modified:"
  echo "$modified_skills" | head -5 | sed 's/^/  ~ /'
fi
if [ -n "$deleted_skills" ]; then
  echo "Deleted:"
  echo "$deleted_skills" | sed 's|skills/||;s|/SKILL.md||' | sed 's/^/  - /'
fi
echo ""
echo "Run: scripts/bump-version.sh $suggested"
echo "Then: git add -A && git commit -m '[meta]: bump version to $suggested' && git push"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

exit 0
